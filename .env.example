# Database (PostgreSQL)
DATABASE_URL=postgresql://agentarch:agentarch@localhost:5432/agentarch

# Redis (BullMQ + pub-sub)
REDIS_URL=redis://localhost:6379

# Google AI Studio – Gemini 2.0 Flash
# Get your free API key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# GitHub OAuth (create at https://github.com/settings/developers)
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Better Auth secret (generate with: openssl rand -hex 32)
BETTER_AUTH_SECRET=change_me_to_a_long_random_secret

# Server
PORT=8080

# Frontend URL (used for CORS and OAuth redirects)
FRONTEND_URL=http://localhost:3000
